{
  "name": "handface",
  "version": "0.1.0",
  "description": "Hand gesture to mouse event control library using MediaPipe",
  "type": "module",
  "main": "./dist/handface.umd.cjs",
  "module": "./dist/handface.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/handface.js",
      "require": "./dist/handface.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "keywords": ["mediapipe", "hand-tracking", "gesture", "mouse", "typescript"],
  "license": "MIT"
}
