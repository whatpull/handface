{
  "name": "@whatpull/handface",
  "version": "0.1.0",
  "description": "Hand gesture to mouse event control library using MediaPipe",
  "type": "module",
  "main": "./dist/handface.umd.cjs",
  "module": "./dist/handface.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/handface.js",
      "require": "./dist/handface.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "deploy:demo": "npm run build:demo && gh-pages -d dist-demo",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": ">=0.10.0"
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "gh-pages": "^6.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "keywords": [
    "mediapipe",
    "hand-tracking",
    "gesture",
    "mouse",
    "typescript"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatpull/handface.git"
  },
  "homepage": "https://github.com/whatpull/handface#readme",
  "publishConfig": {
    "access": "public"
  }
}
